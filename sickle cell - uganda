// =============================================
//  APP STATE
// =============================================
let currentRole = 'patient';
let currentScreen = '';
let prevScreen = '';
const screenHistory = [];

// =============================================
//  LOGIN
// =============================================
let selectedLoginRole = 'patient';
function setLoginRole(role, el) {
  selectedLoginRole = role;
  document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}
function doLogin() {
  const email = document.getElementById('login-email').value;
  if (!email) { alert('Please enter an email address.'); return; }
  quickLogin(selectedLoginRole);
}
function quickLogin(role) {
  currentRole = role;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app-shell').style.display = 'flex';
  setupSidebar(role);
  if (role === 'patient')  navigate('screen-home');
  if (role === 'doctor')   navigate('screen-doctor-home');
  if (role === 'admin')    navigate('screen-admin-home');
}
function doLogout() {
  document.getElementById('app-shell').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-email').value = '';
  document.getElementById('login-pass').value = '';
  currentRole = 'patient';
}

// =============================================
//  SIDEBAR SETUP
// =============================================
const navConfig = {
  patient: {
    name: 'Amara Nakato',
    role: 'Patient',
    avatarClass: 'ua-patient',
    initials: 'AN',
    sections: [
      { label: 'Overview', items: [
        { icon:'🏠', label:'Home',           screen:'screen-home' },
        { icon:'🏥', label:'Find Hospitals', screen:'screen-hospitals' },
        { icon:'📅', label:'My Appointments',screen:'screen-my-appointments' },
        { icon:'📋', label:'My History',     screen:'screen-profile' },
        { icon:'💊', label:'My Care Advice', screen:'screen-recommendations' },
      ]},
      { label: 'Help', items: [
        { icon:'🚨', label:'Emergency Help', screen:'screen-emergency' },
        { icon:'📅', label:'Book Appointment',screen:'screen-book' },
      ]}
    ]
  },
  doctor: {
    name: 'Dr. David Nsereko',
    role: 'Doctor — Hematologist',
    avatarClass: 'ua-doctor',
    initials: 'DN',
    sections: [
      { label: 'Doctor Portal', items: [
        { icon:'🏠', label:'Dashboard',     screen:'screen-doctor-home' },
        { icon:'📅', label:'My Schedule',   screen:'screen-doctor-home' },
        { icon:'👥', label:'My Patients',   screen:'screen-doctor-patients' },
        { icon:'🏥', label:'Find Hospitals',screen:'screen-hospitals' },
      ]},
      { label: 'Help', items: [
        { icon:'🚨', label:'Emergency Info',screen:'screen-emergency' },
      ]}
    ]
  },
  admin: {
    name: 'Admin User',
    role: 'System Administrator',
    avatarClass: 'ua-admin',
    initials: 'AD',
    sections: [
      { label: 'Administration', items: [
        { icon:'🏠', label:'Dashboard',          screen:'screen-admin-home' },
        { icon:'🏥', label:'Hospitals',          screen:'screen-hospitals' },
        { icon:'👨‍⚕️', label:'Doctors',          screen:'screen-admin-users' },
        { icon:'👤', label:'User Management',    screen:'screen-admin-users' },
        { icon:'📋', label:'Clinical Records',   screen:'screen-admin-add-record' },
      ]},
      { label: 'Add New', items: [
        { icon:'🏥', label:'Add Hospital',       screen:'screen-admin-add-hospital' },
        { icon:'👨‍⚕️', label:'Register Doctor', screen:'screen-admin-add-doctor' },
        { icon:'📋', label:'Add Record',         screen:'screen-admin-add-record' },
      ]}
    ]
  }
};

function setupSidebar(role) {
  const cfg = navConfig[role];
  document.getElementById('sidebar-name').textContent = cfg.name;
  document.getElementById('sidebar-role').textContent = cfg.role;
  const av = document.getElementById('sidebar-avatar');
  av.textContent = cfg.initials;
  av.className = 'user-avatar ' + cfg.avatarClass;

  let html = '';
  cfg.sections.forEach(section => {
    html += `<div class="nav-section-label">${section.label}</div>`;
    section.items.forEach(item => {
      html += `<div class="nav-item" data-screen="${item.screen}" onclick="navigate('${item.screen}')">
        <span class="nav-icon">${item.icon}</span>
        <span>${item.label}</span>
      </div>`;
    });
  });
  document.getElementById('sidebar-nav').innerHTML = html;
}

// =============================================
//  NAVIGATION
// =============================================
const screenTitles = {
  'screen-home':                'Home',
  'screen-hospitals':           'Find Hospitals',
  'screen-hospital-detail':     'Hospital Profile',
  'screen-my-appointments':     'My Appointments',
  'screen-profile':             'Patient Profile',
  'screen-recommendations':     'My Care Advice',
  'screen-emergency':           'Emergency Help',
  'screen-book':                'Book Appointment',
  'screen-doctor-home':         'Doctor Dashboard',
  'screen-doctor-patients':     'My Patients',
  'screen-admin-home':          'Admin Dashboard',
  'screen-admin-add-hospital':  'Add Hospital',
  'screen-admin-add-doctor':    'Register Doctor',
  'screen-admin-add-record':    'Add Clinical Record',
  'screen-admin-users':         'User Management',
};

function navigate(id) {
  if (currentScreen) {
    const el = document.getElementById(currentScreen);
    if (el) el.classList.remove('active');
    if (!screenHistory.includes(currentScreen)) screenHistory.push(currentScreen);
    else screenHistory.push(currentScreen);
  }
  prevScreen = currentScreen;
  currentScreen = id;

  const el = document.getElementById(id);
  if (el) el.classList.add('active');

  document.getElementById('topbar-title').textContent = screenTitles[id] || 'SickleCare';

  // Update nav active state
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.toggle('active', n.dataset.screen === id);
  });

  // Show/hide readonly banner for profile when doctor views it
  const ropb = document.getElementById('readonly-banner-profile');
  if (ropb) ropb.style.display = (id === 'screen-profile' && currentRole === 'doctor') ? 'flex' : 'none';

  // Reset booking steps
  if (id === 'screen-book') resetBooking();

  window.scrollTo(0, 0);
}

// =============================================
//  TAB SWITCHING
// =============================================
function switchTab(containerId, tabId, el) {
  const container = document.getElementById(containerId);
  if (!container) return;
  container.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById(tabId).classList.add('active');
  const bar = el.closest('.tab-bar');
  if (bar) bar.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// =============================================
//  BOOKING FLOW
// =============================================
function selectDoctor(num) {
  document.querySelectorAll('.doctor-select-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('dsc-' + num).classList.add('selected');
}
function pickDay(el) {
  document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
  el.classList.add('selected');
}
function pickTime(el) {
  if (el.classList.contains('unavail')) return;
  document.querySelectorAll('.time-slot').forEach(t => t.classList.remove('selected'));
  el.classList.add('selected');
}
function bookNextStep(step) {
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('book-step-' + i);
    if (el) el.style.display = i === step ? 'block' : 'none';
  }
  for (let i = 1; i <= 3; i++) {
    const bs = document.getElementById('bs' + i);
    if (!bs) continue;
    bs.className = 'bstep' + (i < step ? ' done' : i === step ? ' active' : '');
  }
  if (step === 4) {
    document.getElementById('booking-steps').style.display = 'none';
  }
}
function resetBooking() {
  bookNextStep(1);
  document.getElementById('booking-steps').style.display = 'flex';
}

// =============================================
//  SUCCESS MODAL
// =============================================
function showSuccess(title, sub) {
  document.getElementById('success-title').textContent = title;
  document.getElementById('success-sub').textContent = sub;
  document.getElementById('success-modal').style.display = 'flex';
}
function closeSuccess() {
  document.getElementById('success-modal').style.display = 'none';
  navigate('screen-admin-home');
}

// =============================================
//  GLOBAL SEARCH
// =============================================
function globalSearch(val) {
  if (!val) return;
  if (val.toLowerCase().includes('hosp')) navigate('screen-hospitals');
  else if (val.toLowerCase().includes('appoint')) navigate('screen-my-appointments');
  else if (val.toLowerCase().includes('rec') || val.toLowerCase().includes('med')) navigate('screen-recommendations');
}

// =============================================
//  FILTER CHIPS
// =============================================
document.addEventListener('click', function(e) {
  if (e.target.classList.contains('filter-chip')) {
    const siblings = e.target.closest('.filter-bar').querySelectorAll('.filter-chip');
    siblings.forEach(c => c.classList.remove('active'));
    e.target.classList.add('active');
  }
});
</script>
